{
  "name": "vscode-better-open-file",
  "displayName": "Better Open File",
  "version": "0.0.0",
  "description": "A Windows-style custom file open dialog for Visual Studio Code.",
  "categories": [
    "Other"
  ],
  "keywords": [
    "dialog",
    "file",
    "open",
    "windows"
  ],
  "homepage": "https://github.com/Zamiell/vscode-better-open-file",
  "bugs": {
    "url": "https://github.com/Zamiell/vscode-better-open-file/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Zamiell/vscode-better-open-file.git"
  },
  "license": "GPL-3.0",
  "author": "Zamiell",
  "publisher": "Zamiell",
  "type": "module",
  "main": "./dist/extension.js",
  "files": [
    "dist",
    "media"
  ],
  "scripts": {
    "build": "bun run ./scripts/build.ts",
    "lint": "bun run ./scripts/lint.ts",
    "package": "bun run build && vsce package",
    "publish": "vsce publish",
    "update": "complete-cli update"
  },
  "contributes": {
    "commands": [
      {
        "command": "betterOpenFile.openFile",
        "title": "Open File",
        "category": "Better Open File"
      }
    ],
    "configuration": {
      "title": "Better Open File",
      "properties": {
        "betterOpenFile.initialDirectory": {
          "type": "string",
          "enum": [
            "workspaceRoot",
            "currentEditor",
            "home",
            "lastUsed"
          ],
          "default": "workspaceRoot",
          "description": "Controls which directory is shown first when the Better Open File dialog opens."
        },
        "betterOpenFile.showHiddenFiles": {
          "type": "boolean",
          "default": false,
          "description": "Show hidden files and directories in the Better Open File dialog."
        },
        "betterOpenFile.allowMultipleSelection": {
          "type": "boolean",
          "default": false,
          "description": "Allow selecting and opening multiple files at once."
        },
        "betterOpenFile.foldersFirst": {
          "type": "boolean",
          "default": true,
          "description": "Sort folders before files in the Better Open File dialog."
        }
      }
    }
  },
  "devDependencies": {
    "@types/vscode": "1.100.0",
    "@vscode/vsce": "3.6.0",
    "complete-common": "2.27.1",
    "complete-lint": "5.11.0",
    "complete-node": "16.4.1",
    "eslint": "10.1.0",
    "eslint-config-complete": "4.7.2",
    "typescript": "6.0.3"
  },
  "engines": {
    "vscode": "^1.100.0"
  }
}
